        <script><![CDATA[(function executeRule(current, previous) {

    var gr = new GlideRecord('x_1919953_parul_0_student_master');

    gr.addQuery(
        'mobile_number',
        current.mobile_number
    );

    gr.query();

    if (gr.next()) {

        gs.addErrorMessage(
            'Mobile Number already registered.'
        );

        current.setAbortAction(true);
        return;
    }

    var emailCheck = new GlideRecord(
        'x_1919953_parul_0_student_master'
    );

    emailCheck.addQuery(
        'personal_email',
        current.personal_email
    );

    emailCheck.query();

    if (emailCheck.next()) {

        gs.addErrorMessage(
            'Personal Email already registered.'
        );

        current.setAbortAction(true);
    }

})(current, previous);]]></script>
