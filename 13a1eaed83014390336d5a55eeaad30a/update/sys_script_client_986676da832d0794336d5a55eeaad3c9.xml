        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {

    if (isLoading || newValue == '') {
        return;
    }

    var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!regex.test(newValue)) {

        g_form.showFieldMsg(
            'personal_email',
            'Enter a valid email address.',
            'error'
        );

    }

}]]></script>
