        <script><![CDATA[(function executeRule(current, previous) {

    var year = new GlideDateTime().getYearUTC();

    var count = new GlideAggregate('x_1919953_parul_0_student_master');
    count.addAggregate('COUNT');
    count.query();

    var total = 0;

    if (count.next()) {
        total = parseInt(count.getAggregate('COUNT')) + 1;
    }

    current.enrollment_number =
        "PU" + year + ("000" + total).slice(-4);
	
	current.email = current.enrollment_number + "@paruluniversity.ac.in";
	

})(current, previous);]]></script>
