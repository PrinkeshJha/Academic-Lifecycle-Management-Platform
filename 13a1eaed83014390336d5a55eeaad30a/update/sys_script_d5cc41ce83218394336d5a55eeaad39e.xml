        <script><![CDATA[(function executeRule(current, previous) {

    if (current.status.changes()) {

        if (current.status == 'approved' || current.status == 'rejected') {

            var history = new GlideRecord('x_1919953_parul_0_approval_history');

            history.initialize();

            history.student = current.sys_id;
            history.action = current.status;
            history.action_by = gs.getUserID();
            history.action_date = new GlideDateTime();

            if (current.status == 'rejected')
                history.comments = current.rejection_reason;

            else
                history.comments = 'Student Approved';

            history.insert();
        }
    }

})(current, previous);]]></script>
