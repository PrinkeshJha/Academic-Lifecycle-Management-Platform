        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {

    if (isLoading || newValue == '') {
        return;
    }

    var ga = new GlideAjax('DepartmentHelper');

    ga.addParam(
        'sysparm_name',
        'getDepartment'
    );

    ga.addParam(
        'sysparm_branch',
        newValue
    );

    ga.getXMLAnswer(function(answer) {

        g_form.setValue(
            'department',
            answer
        );

    });

}]]></script>
